# ═══════════════════════════════════════════════════
# Agent Evaluation Platform - Environment Variables
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ─── Django ───
SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=False

# ─── PostgreSQL ───
POSTGRES_PASSWORD=eval_password_2026
# DATABASE_URL is auto-configured by docker-compose

# ─── Redis ───
# REDIS_URL and CELERY_BROKER_URL are auto-configured by docker-compose

# ─── Judge Model (LLM for G-Eval metrics) ───
# Required for LLM-based metrics (correctness, relevance, etc.)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# ─── MLflow (Experiment Tracking) ───
# MLFLOW_TRACKING_URI is auto-configured by docker-compose
# ===== Django =====
SECRET_KEY=django-insecure-dev-key-change-in-production
DJANGO_SETTINGS_MODULE=config.settings
DEBUG=True

# ===== Database =====
DATABASE_URL=postgresql://eval_user:eval_password_2026@localhost:5432/agent_eval
POSTGRES_PASSWORD=eval_password_2026

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ===== MLflow =====
MLFLOW_TRACKING_URI=http://localhost:5000

# ===== Judge Model (OpenAI Compatible) =====
OPENAI_API_KEY=sk-your-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# ===== S3/OSS (optional) =====
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
